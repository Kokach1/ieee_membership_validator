{
    "manifest_version": 3,
    "name": "IEEE Membership Validator Automation",
    "version": "1.0.0",
    "description": "Automate IEEE membership validation from Excel files",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "notifications"
    ],
    "host_permissions": [
        "https://services24.ieee.org/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://services24.ieee.org/membership-validator.html*",
                "https://services24.ieee.org/membership-validator*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "lib/xlsx.full.min.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    }
}